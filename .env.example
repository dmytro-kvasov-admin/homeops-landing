# Resend — transactional email
# Get your API key from resend.com/api-keys
RESEND_API_KEY=re_CGs3AtKG_4oDhvCgpNMyS1o9ThakVNYM9

# Where new waitlist signup notifications are delivered.
RESEND_ADMIN_EMAIL=homeopsaiapp@gmail.com

# Flip to "true" once you verify a sending domain at resend.com/domains.
# When false (or unset), the customer confirmation email is skipped — Resend's
# sandbox sender (`onboarding@resend.dev`) can only deliver to RESEND_ADMIN_EMAIL.
RESEND_DOMAIN_VERIFIED=false

# Custom sender, only used when RESEND_DOMAIN_VERIFIED=true.
# Format: "Display Name <address@yourdomain.com>"
# RESEND_FROM_EMAIL=HomeOps <noreply@homeops.us>

# Canonical site URL — used for SEO metadata (canonical tag, JSON-LD, OpenGraph url).
NEXT_PUBLIC_SITE_URL=https://homeops.us

# PostHog — product analytics + session replay
# Project API key from app.posthog.com → Project settings (starts with "phc_").
# If missing, analytics is silently disabled (the app still works).
NEXT_PUBLIC_POSTHOG_KEY=phc_uqSUAzVQSCYyQ5pMEGvUEPH9Vxn2ocYraZ8SpfJmmobV
# US Cloud is the default. Use https://eu.i.posthog.com if your project is on EU Cloud.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
