# Resend — transactional email and waitlist contacts
# Get your API key from resend.com/api-keys
RESEND_API_KEY=

# From address for outbound emails.
# Must be a domain you've verified in Resend (resend.com/domains).
# You cannot send from a Gmail address — Resend requires a custom domain.
# While testing, leave this empty to use the Resend sandbox address (onboarding@resend.dev).
RESEND_FROM_EMAIL=

# Where new waitlist signup notifications are sent (can be any email, including Gmail).
RESEND_ADMIN_EMAIL=homeopsaiapp@gmail.com

# Canonical site URL — used for SEO metadata (canonical tag, JSON-LD, OpenGraph url).
# Set this to your production domain before deploying.
NEXT_PUBLIC_SITE_URL=https://homeopsapp.com
